    {
      "cell_type": "code",
      "source": [
        "# ==========================================================\n",
        "# PRÁTICA 15 - REDE NEURAL ARTIFICIAL COM MLPCLASSIFIER\n",
        "# Objetivo:\n",
        "# Utilizar uma Rede Neural Artificial para prever o\n",
        "# comportamento dos agentes presentes no arquivo iafile01.csv\n",
        "# ==========================================================\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Importação das bibliotecas\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Biblioteca utilizada para leitura e manipulação dos dados\n",
        "import pandas as pd\n",
        "\n",
        "# Função responsável por dividir os dados em treino e teste\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "# Utilizada para normalizar os atributos numéricos\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "# Implementação da Rede Neural Artificial Multilayer Perceptron\n",
        "from sklearn.neural_network import MLPClassifier\n",
        "\n",
        "# Métricas utilizadas para avaliar o desempenho do modelo\n",
        "from sklearn.metrics import (\n",
        "    accuracy_score,\n",
        "    confusion_matrix,\n",
        "    classification_report\n",
        ")\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Carregamento do dataset\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Leitura do arquivo CSV contendo os dados dos agentes\n",
        "dados = pd.read_csv(\"iafile01.csv\")\n",
        "\n",
        "# Exibe as primeiras linhas do conjunto de dados\n",
        "print(\"Primeiras linhas do dataset:\")\n",
        "print(dados.head())\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Definição das variáveis de entrada (X)\n",
        "# e da variável alvo (y)\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Seleciona os atributos que serão utilizados pela RNA\n",
        "# para aprender padrões e realizar previsões\n",
        "X = dados[['TPU', 'NUR', 'Inventario', 'TCR']]\n",
        "\n",
        "# Define a coluna que representa o comportamento do agente\n",
        "# Esta é a informação que a rede neural deverá prever\n",
        "y = dados['Comportamento']\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Divisão dos dados em treinamento e teste\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# 70% dos dados serão utilizados para treinamento\n",
        "# 30% dos dados serão utilizados para teste\n",
        "\n",
        "# random_state=42 garante que a divisão seja reproduzível\n",
        "X_treino, X_teste, y_treino, y_teste = train_test_split(\n",
        "    X,\n",
        "    y,\n",
        "    test_size=0.30,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "# Exibe a quantidade de registros em cada conjunto\n",
        "print(\"\\nQuantidade de registros:\")\n",
        "print(\"Treino:\", len(X_treino))\n",
        "print(\"Teste :\", len(X_teste))\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Normalização dos dados\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# A normalização coloca os atributos em uma escala semelhante,\n",
        "# evitando que valores muito grandes influenciem excessivamente\n",
        "# o treinamento da Rede Neural Artificial.\n",
        "\n",
        "scaler = StandardScaler()\n",
        "\n",
        "# Ajusta os parâmetros de normalização nos dados de treino\n",
        "# e aplica a transformação\n",
        "X_treino = scaler.fit_transform(X_treino)\n",
        "\n",
        "# Aplica a mesma transformação aos dados de teste\n",
        "X_teste = scaler.transform(X_teste)\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Construção da Rede Neural Artificial\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# hidden_layer_sizes=(10,5)\n",
        "# Primeira camada oculta com 10 neurônios\n",
        "# Segunda camada oculta com 5 neurônios\n",
        "\n",
        "# activation='relu'\n",
        "# Função de ativação responsável por introduzir não-linearidade\n",
        "\n",
        "# solver='adam'\n",
        "# Algoritmo utilizado para otimizar os pesos da rede\n",
        "\n",
        "# max_iter=1000\n",
        "# Número máximo de ciclos de treinamento\n",
        "\n",
        "rna = MLPClassifier(\n",
        "    hidden_layer_sizes=(10, 5),\n",
        "    activation='relu',\n",
        "    solver='adam',\n",
        "    max_iter=1000,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Treinamento da Rede Neural\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Nesta etapa a RNA analisa os exemplos do conjunto de treino\n",
        "# e ajusta seus pesos internos para aprender os padrões\n",
        "# existentes nos dados.\n",
        "\n",
        "rna.fit(X_treino, y_treino)\n",
        "\n",
        "print(\"\\nTreinamento concluído com sucesso!\")\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Realização das previsões\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Utiliza os dados de teste para verificar se a rede neural\n",
        "# consegue identificar corretamente o comportamento dos agentes\n",
        "\n",
        "previsoes = rna.predict(X_teste)\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Avaliação do modelo\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Acurácia:\n",
        "# Percentual total de classificações corretas\n",
        "\n",
        "acuracia = accuracy_score(y_teste, previsoes)\n",
        "\n",
        "print(\"\\n================ RESULTADOS ================\")\n",
        "print(\"Acurácia:\", acuracia)\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Matriz de Confusão\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Mostra quantas previsões foram corretas e incorretas\n",
        "# para cada classe (A, B e C)\n",
        "\n",
        "print(\"\\nMatriz de Confusão:\")\n",
        "print(confusion_matrix(y_teste, previsoes))\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Relatório de Classificação\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "# Precision:\n",
        "# Das previsões realizadas para uma classe,\n",
        "# quantas estavam corretas.\n",
        "\n",
        "# Recall:\n",
        "# Quantos exemplos reais da classe foram encontrados.\n",
        "\n",
        "# F1-Score:\n",
        "# Média harmônica entre Precision e Recall.\n",
        "\n",
        "# Support:\n",
        "# Quantidade de exemplos existentes de cada classe.\n",
        "\n",
        "print(\"\\nRelatório de Classificação:\")\n",
        "print(classification_report(y_teste, previsoes))\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# Conclusão automática\n",
        "# ----------------------------------------------------------\n",
        "\n",
        "print(\"\\nConclusão:\")\n",
        "print(\n",
        "    f\"O modelo alcançou uma acurácia de {acuracia:.2%}, \"\n",
        "    \"demonstrando sua capacidade de prever corretamente \"\n",
        "    \"o comportamento dos agentes presentes no dataset.\"\n",
        ")"
      ],
